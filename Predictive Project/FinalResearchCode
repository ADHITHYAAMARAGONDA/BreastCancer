test_significance <- function(models, label="") {
  cat("\n=== Statistical Significance:", label, "===\n")
  res     <- resamples(models)
  diff_res <- diff(res)
  print(summary(diff_res))

  # Visualizations for paper
  p1 <- dotplot(res,  metric = "ROC",
                main = paste("CV ROC Distribution -", label))
  p2 <- bwplot(res,   metric = "ROC",
               main = paste("ROC Boxplot -", label))
  print(p1)
  print(p2)

  return(res)
}

res_full    <- test_significance(models_full,    "Full Features")
res_reduced <- test_significance(models_reduced, "Corr-Reduced")
res_rfe     <- test_significance(models_rfe,     "RFE Features")

# ============================================================
# SECTION 8: MULTI-MODEL ROC CURVES (ALL 3 FEATURE SETS)
# ============================================================

plot_roc_comparison <- function(models, testData, title="ROC Comparison") {

  colors <- c("blue","green4","orange","red","purple")
  roc_list <- lapply(models, function(m) {
    prob <- predict(m, testData, type = "prob")
    roc(testData$diagnosis, prob$Malignant, quiet = TRUE)
  })

  plot(roc_list[[1]], col = colors[1], lwd = 2,
       main = title, legacy.axes = TRUE)

  for (i in 2:length(roc_list)) {
    plot(roc_list[[i]], col = colors[i], lwd = 2, add = TRUE)
  }

  legend("bottomright",
         legend = paste(names(roc_list),
                        "| AUC =",
                        round(sapply(roc_list, auc), 3)),
         col    = colors,
         lwd    = 2,
         cex    = 0.85)
}

par(mfrow = c(1,3))
plot_roc_comparison(models_full,    split_full$test,    "ROC - Full Features")
plot_roc_comparison(models_reduced, split_reduced$test, "ROC - Corr-Reduced")
plot_roc_comparison(models_rfe,     split_rfe$test,     "ROC - RFE Features")
par(mfrow = c(1,1))

