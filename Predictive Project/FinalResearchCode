build_summary <- function(eval_df, label) {
  eval_df$FeatureSet <- label
  return(eval_df)
}

final_summary <- rbind(
  build_summary(eval_full,    "Full (30)"),
  build_summary(eval_reduced, "Corr-Reduced"),
  build_summary(eval_rfe,     paste0("RFE (", length(best_features), ")"))
)

cat("\n========== FINAL CROSS-FEATURE-SET SUMMARY ==========\n")
print(final_summary[order(final_summary$AUC, decreasing=TRUE), ])

# ============================================================
# SECTION 11: SENSITIVITY-FOCUSED VISUALIZATION (CLINICAL)
# ============================================================
# WHY: Sensitivity = detecting actual cancer cases.
# A model with 96% accuracy but 80% sensitivity
# misses 20% of cancer patients. That must be highlighted.

ggplot(final_summary,
       aes(x = Model, y = Sensitivity, fill = FeatureSet)) +
  geom_bar(stat = "position", position = "dodge") +
  geom_hline(yintercept = 0.95, linetype = "dashed",
             color = "red", linewidth = 0.8) +
  annotate("text", x = 1, y = 0.96,
           label = "Clinical threshold (95%)",
           color = "red", size = 3) +
  labs(title    = "Sensitivity Comparison Across Models & Feature Sets",
       subtitle = "Sensitivity = correctly identified malignant cases",
       y        = "Sensitivity (Recall for Malignant)",
       x        = "Classifier") +
  theme_minimal() +
  theme(legend.position = "bottom")

# Missed cancer cases heatmap
ggplot(final_summary,
       aes(x = Model, y = FeatureSet, fill = FalseNeg)) +
  geom_tile(color = "white") +
  geom_text(aes(label = FalseNeg), size = 5) +
  scale_fill_gradient(low = "white", high = "red") +
  labs(title = "False Negatives (Missed Cancer Cases) Heatmap",
       fill  = "Missed Cases") +
  theme_minimal()

