# ── LIBRARIES ───────────────────────────────────────────────
library(caret)
library(e1071)
library(rpart)
library(randomForest)
library(pROC)
library(ggplot2)
library(corrplot)      # correlation heatmap
library(dplyr)         # data wrangling
library(gridExtra)     # arrange multiple plots
library(DALEX)         # explainability (SHAP-style)
library(lime)          # local interpretability

set.seed(123)

# ============================================================
# SECTION 1: DATA LOADING & PREPROCESSING
# ============================================================

wbcd <- read.csv("wisc_bc_data.csv", stringsAsFactors = FALSE)
wbcd <- wbcd[-1]   # remove ID column

wbcd$diagnosis <- factor(wbcd$diagnosis,
                          levels = c("B", "M"),
                          labels = c("Benign", "Malignant"))

cat("Class Distribution:\n")
print(round(prop.table(table(wbcd$diagnosis)) * 100, 2))
# WHY: Checking class imbalance upfront is required in any
# medical ML paper. Imbalanced classes affect sensitivity
# which matters most clinically (missing cancer = fatal).

# ── Standardization ─────────────────────────────────────────
preProcValues <- preProcess(wbcd[, -1], method = c("center", "scale"))
wbcd_scaled   <- predict(preProcValues, wbcd[, -1])
wbcd_final    <- data.frame(diagnosis = wbcd$diagnosis, wbcd_scaled)

# ============================================================
# SECTION 2: FEATURE SELECTION (YOUR MAIN CONTRIBUTION #1)
# ============================================================
# WHY THIS IS NOVEL: Most WBCD papers use all 30 features.
# You will compare full vs. reduced feature sets and show
# which features matter most — clinically actionable insight.

# ── 2A. Correlation-based removal ───────────────────────────
corMatrix <- cor(wbcd_scaled)

# Visualize correlation heatmap (include this figure in paper)
corrplot(corMatrix,
         method = "color",
         type   = "upper",
         tl.cex = 0.7,
         title  = "Feature Correlation Heatmap",
         mar    = c(0,0,1,0))

# Remove features with correlation > 0.90
highCorFeatures <- findCorrelation(corMatrix, cutoff = 0.90)
cat("\nRemoved highly correlated features (indices):", highCorFeatures, "\n")
cat("Features removed:", names(wbcd_scaled)[highCorFeatures], "\n")

wbcd_reduced      <- wbcd_scaled[, -highCorFeatures]
wbcd_final_reduced <- data.frame(diagnosis = wbcd$diagnosis, wbcd_reduced)

cat("\nOriginal feature count:", ncol(wbcd_scaled), "\n")
cat("Reduced feature count: ", ncol(wbcd_reduced), "\n")

# ── 2B. Recursive Feature Elimination (RFE) ─────────────────
# WHY: RFE finds the OPTIMAL subset, not just removes correlated
# ones. This is a stronger feature selection method and gives
# you a third dataset to compare (full / corr-reduced / RFE)

rfe_control <- rfeControl(functions = rfFuncs,
                           method    = "cv",
                           number    = 10)

rfe_result <- rfe(wbcd_scaled,
                  wbcd$diagnosis,
                  sizes    = c(5, 10, 15, 20),
                  rfeControl = rfe_control)

print(rfe_result)
plot(rfe_result, type = c("g","o"),
     main = "RFE: Optimal Number of Features")

best_features       <- predictors(rfe_result)
cat("\nRFE selected features:\n")
print(best_features)

wbcd_rfe      <- wbcd_scaled[, best_features]
wbcd_final_rfe <- data.frame(diagnosis = wbcd$diagnosis, wbcd_rfe)

# ============================================================
# SECTION 3: TRAIN-TEST SPLIT (ALL THREE DATASETS)
# ============================================================

split_data <- function(df) {
  idx   <- createDataPartition(df$diagnosis, p = 0.8, list = FALSE)
  list(train = df[idx, ], test = df[-idx, ])
}

split_full    <- split_data(wbcd_final)
split_reduced <- split_data(wbcd_final_reduced)
split_rfe     <- split_data(wbcd_final_rfe)

# ============================================================
# SECTION 4: CROSS-VALIDATION SETUP
# ============================================================

control <- trainControl(
  method          = "cv",
  number          = 10,
  classProbs      = TRUE,
  summaryFunction = twoClassSummary,
  savePredictions = "final"   # needed for calibration plots
)

# ============================================================
# SECTION 5: MODEL TRAINING FUNCTION
# ============================================================
# WHY A FUNCTION: Trains all 5 models on any dataset,
# lets you run full/reduced/RFE comparison cleanly

train_all_models <- function(trainData) {

  m_lr <- train(diagnosis ~ ., data = trainData,
                method   = "glm",
                family   = "binomial",
                trControl = control,
                metric   = "ROC")

  m_knn <- train(diagnosis ~ ., data = trainData,
                 method    = "knn",
                 tuneLength = 10,
                 trControl  = control,
                 metric     = "ROC")

  m_dt <- train(diagnosis ~ ., data = trainData,
                method    = "rpart",
                tuneLength = 10,
                trControl  = control,
                metric     = "ROC")

  m_rf <- train(diagnosis ~ ., data = trainData,
                method    = "rf",
                tuneLength = 5,
                trControl  = control,
                metric     = "ROC")

  m_svm <- train(diagnosis ~ ., data = trainData,
                 method    = "svmRadial",
                 tuneLength = 10,
                 trControl  = control,
                 metric     = "ROC")

  list(LR=m_lr, KNN=m_knn, DT=m_dt, RF=m_rf, SVM=m_svm)
}

cat("\n=== Training on FULL feature set ===\n")
models_full    <- train_all_models(split_full$train)

cat("\n=== Training on CORRELATION-REDUCED feature set ===\n")
models_reduced <- train_all_models(split_reduced$train)

cat("\n=== Training on RFE-SELECTED feature set ===\n")
models_rfe     <- train_all_models(split_rfe$train)

# ============================================================
# SECTION 6: EVALUATION FUNCTION (YOUR CONTRIBUTION #2)
# ============================================================
# WHY: Reports Sensitivity separately — the most clinically
# critical metric. Missing a malignant case (false negative)
# is far more dangerous than a false positive.

evaluate_models <- function(models, testData, label="") {

  cat("\n====", label, "====\n")

  res <- lapply(names(models), function(nm) {
    m          <- models[[nm]]
    pred_class <- predict(m, testData)
    pred_prob  <- predict(m, testData, type = "prob")

    cm  <- confusionMatrix(pred_class,
                           testData$diagnosis,
                           positive = "Malignant")
    roc_o <- roc(testData$diagnosis,
                 pred_prob$Malignant,
                 quiet = TRUE)

    data.frame(
      Model       = nm,
      Accuracy    = round(cm$overall["Accuracy"],    4),
      Sensitivity = round(cm$byClass["Sensitivity"], 4),  # recall for Malignant
      Specificity = round(cm$byClass["Specificity"], 4),
      Precision   = round(cm$byClass["Pos Pred Value"], 4),
      F1          = round(cm$byClass["F1"],           4),
      AUC         = round(as.numeric(auc(roc_o)),     4),
      FalseNeg    = cm$table["Benign","Malignant"]    # missed cancers
    )
  })

  result_df <- do.call(rbind, res)
  rownames(result_df) <- NULL
  print(result_df)
  return(result_df)
}

eval_full    <- evaluate_models(models_full,    split_full$test,    "FULL FEATURES")
eval_reduced <- evaluate_models(models_reduced, split_reduced$test, "CORR-REDUCED FEATURES")
eval_rfe     <- evaluate_models(models_rfe,     split_rfe$test,     "RFE FEATURES")

