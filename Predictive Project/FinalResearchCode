# ============================================================
# SECTION 7: MODEL TRAINING FUNCTION
# ============================================================
# Trains all 5 classifiers on any given dataset.
# Encapsulated as function to run cleanly on 3 feature sets.

train_all_models <- function(trainData, label = "") {
  cat("\n>>> Training models on:", label, "<<<\n")
  
  # 1. Logistic Regression
  cat("  [1/5] Logistic Regression...\n")
  m_lr <- train(diagnosis ~ .,
                data      = trainData,
                method    = "glm",
                family    = "binomial",
                trControl = control,
                metric    = "ROC")
  
  # 2. K-Nearest Neighbors (auto-tuned k)
  cat("  [2/5] KNN...\n")
  m_knn <- train(diagnosis ~ .,
                 data       = trainData,
                 method     = "knn",
                 tuneLength = 10,      # tests k = 5,7,9,...,23
                 trControl  = control,
                 metric     = "ROC")
  
  # 3. Decision Tree (CART with complexity tuning)
  cat("  [3/5] Decision Tree...\n")
  m_dt <- train(diagnosis ~ .,
                data       = trainData,
                method     = "rpart",
                tuneLength = 10,
                trControl  = control,
                metric     = "ROC")
  
  # 4. Random Forest (ensemble of trees)
  cat("  [4/5] Random Forest...\n")
  m_rf <- train(diagnosis ~ .,
                data       = trainData,
                method     = "rf",
                tuneLength = 5,       # tests 5 mtry values
                trControl  = control,
                metric     = "ROC")
  
  # 5. SVM with Radial Basis Function kernel
  cat("  [5/5] SVM (RBF kernel)...\n")
  m_svm <- train(diagnosis ~ .,
                 data       = trainData,
                 method     = "svmRadial",
                 tuneLength = 10,
                 trControl  = control,
                 metric     = "ROC")
  
  cat("  Training complete for:", label, "\n")
  list(LR = m_lr, KNN = m_knn, DT = m_dt, RF = m_rf, SVM = m_svm)
}

