plot_roc_all <- function(models, testData, title, filename) {
  colors  <- c("blue", "darkgreen", "orange", "red", "purple")
  ltypes  <- c(1, 2, 3, 4, 5)
  
  roc_list <- lapply(names(models), function(nm) {
    prob <- predict(models[[nm]], testData, type = "prob")
    roc(testData$diagnosis, prob$Malignant, quiet = TRUE)
  })
  names(roc_list) <- names(models)
  
  auc_vals <- round(sapply(roc_list, auc), 4)
  
  png(filename, width = 2800, height = 2400, res = 300)
  plot(roc_list[[1]],
       col          = colors[1],
       lwd          = 2.5,
       lty          = ltypes[1],
       main         = title,
       legacy.axes  = TRUE,
       xlab         = "1 - Specificity (False Positive Rate)",
       ylab         = "Sensitivity (True Positive Rate)",
       cex.main     = 1.1,
       cex.lab      = 1.0)
  
  for (i in 2:length(roc_list)) {
    plot(roc_list[[i]],
         col         = colors[i],
         lwd         = 2.5,
         lty         = ltypes[i],
         add         = TRUE)
  }
  
  abline(a = 0, b = 1, lty = 3, col = "gray50")  # random classifier line
  
  legend("bottomright",
         legend  = paste0(names(roc_list), " (AUC = ", auc_vals, ")"),
         col     = colors,
         lty     = ltypes,
         lwd     = 2.5,
         cex     = 0.85,
         bty     = "n")
  dev.off()
  cat("ROC figure saved:", filename, "\n")
}

