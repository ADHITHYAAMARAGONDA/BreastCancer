# ============================================================
# SECTION 9: STATISTICAL SIGNIFICANCE TESTING — CONTRIBUTION #3
# ============================================================
# WHY THIS IS CRITICAL FOR PUBLICATION:
# Prior WBCD papers report accuracy numbers but NEVER test
# if differences between models are statistically significant.
# We use pairwise t-tests across 10 CV fold results.
# p < 0.05 = the difference is real, not random variation.

run_significance_tests <- function(models, label = "") {
  cat("\n==============================\n")
  cat("SIGNIFICANCE TESTS:", label, "\n")
  cat("==============================\n")
  
  res      <- resamples(models)
  diff_res <-  diff(res)
  
  cat("\nCV Performance Summary:\n")
  print(summary(res))
  
  cat("\nPairwise Significance (p-values for ROC):\n")
  print(summary(diff_res))
  
  return(list(resamples = res, diffs = diff_res))
}

