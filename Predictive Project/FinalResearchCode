# WHY 80/20: Standard split used in comparable literature
# (Naji et al. 2021 used 75/25, Hossin et al. 2023 used 80/20)

split_data <- function(df) {
  idx <- createDataPartition(df$diagnosis, p = 0.80, list = FALSE)
  list(train = df[idx, ], test = df[-idx, ])
}

