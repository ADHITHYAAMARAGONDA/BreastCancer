# ============================================================
# SECTION 8: MODEL EVALUATION FUNCTION — CONTRIBUTION #2
# ============================================================
# WHY SENSITIVITY AS PRIMARY: In cancer diagnosis, a false
# negative (predicting Benign when actually Malignant) leads
# to missed treatment — potentially fatal. Therefore sensitivity
# is ranked BEFORE accuracy in our clinical evaluation.
# This framing is ABSENT from all 5 prior WBCD papers we reviewed.

evaluate_models <- function(models, testData, label = "") {
  cat("\n==============================\n")
  cat("EVALUATION:", label, "\n")
  cat("==============================\n")
  
  res_list <- lapply(names(models), function(nm) {
    m <- models[[nm]]
    
    # Predictions
    pred_class <- predict(m, testData)
    pred_prob  <- predict(m, testData, type = "prob")
    
    # Confusion matrix — positive class is Malignant
    cm <- confusionMatrix(pred_class,
                          testData$diagnosis,
                          positive = "Malignant")
    
    # ROC and AUC
    roc_obj <- roc(testData$diagnosis,
                   pred_prob$Malignant,
                   quiet = TRUE)
    
    # False negatives = missed cancer cases
    # In confusion matrix: actual Malignant predicted as Benign
    fn_count <- cm$table["Benign", "Malignant"]
    
    data.frame(
      Model       = nm,
      Accuracy    = round(cm$overall["Accuracy"],       4),
      Sensitivity = round(cm$byClass["Sensitivity"],    4),
      Specificity = round(cm$byClass["Specificity"],    4),
      Precision   = round(cm$byClass["Pos Pred Value"], 4),
      F1_Score    = round(cm$byClass["F1"],             4),
      AUC         = round(as.numeric(auc(roc_obj)),     4),
      False_Neg   = fn_count,
      stringsAsFactors = FALSE
    )
  })
  
  result_df <- do.call(rbind, res_list)
  rownames(result_df) <- NULL
  
  # Sort by Sensitivity (primary) then AUC (secondary)
  result_df <- result_df[order(-result_df$Sensitivity,
                               -result_df$AUC), ]
  print(result_df)
  return(result_df)
}

